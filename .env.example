# .env.local — Local development environment variables
# Copy this file to .env.local and update values for your environment

# Public site origin — used by app/layout.tsx (metadataBase/OG/JSON-LD),
# app/sitemap.ts, app/robots.ts, and app/feed.xml/route.ts via
# lib/site-config.ts. Only needed here if you want to override the
# production default (e.g. for a staging/preview deploy); the code falls
# back to https://beamedsilicon.qzz.io if this isn't set.
NEXT_PUBLIC_BASE_URL=https://beamedsilicon.qzz.io

# newsdata.io API key used by app/api/news/route.ts. Required in
# production — the route falls back to a legacy key that was hardcoded in
# source control and should be treated as compromised. Get a fresh key at
# https://newsdata.io/register
NEWSDATA_API_KEY=

# Newsletter API endpoint (optional)
# NEXT_PUBLIC_NEWSLETTER_API=https://api.example.com/subscribe

# Analytics tracking ID (optional)
# NEXT_PUBLIC_ANALYTICS_ID=your-tracking-id