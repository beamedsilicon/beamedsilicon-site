# Enforce LF line endings for all text files
* text=auto

# Explicitly use LF for these file types
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Keep Windows line endings for Windows-specific files if needed
# *.bat text eol=crlf
# *.cmd text eol=crlf
