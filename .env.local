NEXT_PUBLIC_BASE_URL=https://beamedsilicon.qzz.io

# Leave NEWSDATA_API_KEY unset locally to use the built-in fallback key in
# app/api/news/route.ts, or paste your own newsdata.io key below. Don't
# set it to an empty string — an empty value still counts as "set" and
# will short-circuit past the code's fallback.
# NEWSDATA_API_KEY=your-key-here